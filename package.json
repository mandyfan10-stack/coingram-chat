{
  "name": "telegram-clone",
  "private": true,
  "version": "1.10.2",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -t -d dist",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-packager . CoinGram --platform=win32 --arch=x64 --out=dist-electron --overwrite",
    "electron:pack": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@supabase/supabase-js": "^2.110.0",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "gh-pages": "^6.3.0",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  },
  "build": {
    "appId": "com.telegram.clone",
    "productName": "CoinGram",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "CoinGram"
    }
  }
}
